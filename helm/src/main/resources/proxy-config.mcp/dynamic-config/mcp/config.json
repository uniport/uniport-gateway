{
    "http": {
        "routers": [
            {
                "name": "mcp",
                "entrypoints": [
                    "mcpHttp20001"
                ],
                "middlewares": [
                    "mcpBearerOnly"
                ],
                "rule": "PathPrefix('/mcp')",
                "service": "mcp"
            },
            {
                "name": "mcp-oauth-protected-resource",
                "entrypoints": [
                    "mcpHttp20001"
                ],
                "rule": "Path('/.well-known/oauth-protected-resource')",
                "service": "mcp"
            }
        ],
        "middlewares": [
            {
                "name": "mcpBearerOnly",
                "type": "bearerOnly",
                "options": {
                    "publicKeys": [
                        {
                            "publicKey": "${UNIPORT_GATEWAY_BEARER_TOKEN_PUBLIC_KEY}"
                        }
                    ],
                    "audience": [
                        "Uniport-Gateway",
                        "Organisation"
                    ],
                    "issuer": "${UNIPORT_GATEWAY_BEARER_TOKEN_ISSUER}",
                    "optional": true
                }
            }
        ],
        "services": [
            {
                "name": "mcp",
                "servers": [
                    {
                        "host": "localhost",
                        "port": 8000
                    }
                ]
            }
        ]
    }
}
